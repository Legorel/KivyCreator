<ProjectsListScreen>:
  projects_grid: projects_grid
  on_enter: self.update_projects_list()

  GridLayout:
    cols: 1

    GridLayout:
      size_hint_y: 0.1
      rows: 1

      Button:
        text: "Settings"
        on_release: app.open_settings()
      Button:
        text: "New project"
        on_release: root.new_project()

    ScrollView:
      do_scroll_x: False
      scroll_type: ["bars", "content"]

      GridLayout:
        id: projects_grid
        size_hint_y: 1
        cols: 1