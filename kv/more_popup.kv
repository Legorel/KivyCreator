<MorePopup>:
  padding: 15, 15
  title_align: "center"
  size_hint: 0.8, 0.4

  GridLayout:
    rows: 2

    GridLayout:
      cols: 2

      Button:
        text: "Run"
      Button:
        size_hint_x: .6
        text: "Export"

    GridLayout:
      cols: 2
      Button:
        text: "Edit"
      Button:
        size_hint_x: .6
        text: "Delete"