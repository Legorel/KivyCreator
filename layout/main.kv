#:import RaiseInTransition kivy.uix.screenmanager.RiseInTransition

MainManager:


<ProjectScreen>:
  scroll: scroll
  ScrollView:
    grid: grid
    id: scroll
    do_scroll_x: False
    size_hint: 1, None
    size: (self.parent.width, self.parent.height)

    GridLayout:
      button: button
      projects: projects
      id: grid
      size_hint: 1, 1.5
      cols: 1
      spacing: 0, 0.5

      GridLayout:
        id: button
        new: new
        size_hint: 1, 0.08 / self.parent.size_hint_y
        rows: 1

        Button:
          id: new
          text: "New Project"
          on_release: app.new_project_popup()
        Button:
          text: "settings"
          on_release: app.open_settings()

      GridLayout:
        id:  projects
        cols: 1


<CodeScreen>:
  main: main
  GridLayout:
    id: main
    manager: manager
    buttons: buttons
    cols: 1

    GridLayout:
      id: buttons
      size_hint: 1, 0.085
      rows: 1

      Button:
        text: "back"
        on_release: app.close_project()

      ToggleButton:
        group: "nav"
        allow_no_selection: False
        state: "down"
        text: "py"
        on_release:
          root.main.manager.transition.direction = "right"
          root.main.manager.current = "py"
      ToggleButton
        group: "nav"
        allow_no_selection: False
        text: "kv"
        on_release:
          root.main.manager.transition.direction = "left"
          root.main.manager.current = "kv"
      Button:
        text: "run"
        on_release: app.check_code()

    CodeManager:
      id: manager
      on_parent: self.transition.duration = 0.3