Popup:
  title: "Unsaved edits"
  size_hint: .8, .4

  GridLayout:
    cols: 1

    Label:
      text: "Save project ?"

    GridLayout
      rows: 1

      Button:
        text: "Cancel"
        on_release: root.dismiss()

      Button:
        text: "No"
        on_release:
          root.dismiss()
          app.root.transition.direction = "right"
          app.root.current = "project"

      Button:
        text: "Yes"
        on_release:
          root.dismiss()
          app.save_project()
          app.root.transition.direction = "right"
          app.root.current = "project"