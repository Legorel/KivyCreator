Popup:
  title: "Save?"
  size_hint: 0.8, 0.3
  
  GridLayout:
    cols: 1
    
    Label:
      text: "Save changes?"
    
    GridLayout:
      rows: 1
      
      Button:
        text: "No"
        on_release: root.dismiss()
      
      Button:
        text: "Yes"
        on_release:
          root.dismiss()
          app.save_project()